DATABASE_URL="postgresql://cnpjscrap:cnpjscrap_dev@localhost:5432/cnpjscrap?schema=app"
REDIS_URL="redis://localhost:6379"

# Senha mestra do painel (protege a raiz / e as APIs). Vazia = sem bloqueio.
# Os links públicos /l/<code> continuam abertos.
PANEL_PASSWORD=""

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-openssl-rand-base64-32"

RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="login@cnpjscrap.local"

# Casa dos Dados — API oficial (paga). Pegue em:
# https://portal.casadosdados.com.br/plataforma/api/chave
# A chave normalmente é salva pelo painel (vai pro banco, em app_settings).
# Esta env é só FALLBACK de dev pra quando não há DATABASE_URL configurada.
CASADOSDADOS_API_KEY=""
